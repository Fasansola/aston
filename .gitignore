# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Alt text backfill progress
scripts/alt-text-progress.json
.claude/
sample.json

# Local dev runtime state (Redis file-adapter fallback) — never commit.
# NB: data/aston_links.json is intentionally tracked (seed data), so list the
# runtime files explicitly rather than globbing data/aston_*.json.
data/aston_queue.json
data/aston_publish_queue.json
data/aston_scheduler_settings.json
